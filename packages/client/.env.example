VITE_API_BASE_URL=http://localhost:3000
# Origin backendu API (bez końcowego slasha). W dev z proxy Vite możesz zostawić puste.
# Gdy puste, assety (modele/tekstury) i tak ładują się z backendu w dev (domyślnie localhost:3000).
# Przykład: VITE_API_BASE_URL=http://localhost:3000
VITE_API_BASE_URL=

# Opcjonalnie: origin backendu tylko do assetów (gdy VITE_API_BASE_URL puste). Domyślnie w dev: http://localhost:3000
# VITE_ASSET_ORIGIN=http://localhost:3000
